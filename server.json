{
    "server_address": ":8081",
    "env": "development",
    "root_path": "./",
    "read_timeout_sec": 15,
    "read_header_timeout_sec": 10,
    "write_timeout_sec": 15,
    "idle_timeout_sec": 60,
    "shutdown_timeout_sec": 10,
    "log_file_name": "app.log",
    "log_max_size_mb": 10,
    "log_level": "INFO",
    "template_dir": "web/templates",
    "static_dir": "web/static",
    "use_tls": false,
    "cert_file": "",
    "key_file": "",
    "allowed_hosts": ["localhost", "127.0.0.1", "myproject.local", "::1"]
}
